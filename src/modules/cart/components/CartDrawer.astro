---
/**
 * CartDrawer.astro
 * Responsabilidad: Panel deslizante lateral del carrito.
 * SSR: renderiza el esqueleto HTML con el panel oculto.
 * Cliente: el <script> se suscribe a nanostores y maneja
 * apertura/cierre, poblado de items y totales.
 *
 * El componente PADRE (BaseLayout) aplica client:load.
 */

export interface Props {
  id?: string;
}

const { id = 'cart-drawer' } = Astro.props;
---

<div
  id={`${id}-overlay`}
  class="fixed inset-0 z-40 bg-black/20 backdrop-blur-sm transition-all duration-300 opacity-0 pointer-events-none"
></div>

<aside
  id={`${id}-panel`}
  class="fixed right-0 top-0 z-50 flex h-full w-full max-w-md flex-col bg-tech-card shadow-drawer transition-all duration-300 ease-in-out translate-x-full"
>
  <div class="flex items-center justify-between border-b border-tech-border px-5 py-4">
    <h2 class="text-base font-semibold text-tech-text-primary">
      Carrito
      <span id={`${id}-count`} class="ml-1 text-sm font-normal text-tech-text-muted"></span>
    </h2>
    <button
      id={`${id}-close`}
      class="flex h-8 w-8 items-center justify-center rounded-full text-tech-text-muted transition-colors hover:bg-tech-bg hover:text-tech-text-primary"
      aria-label="Cerrar carrito"
    >
      <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" y1="4" x2="12" y2="12" />
        <line x1="12" y1="4" x2="4" y2="12" />
      </svg>
    </button>
  </div>

  <div id={`${id}-items`} class="flex-1 overflow-y-auto px-5 py-4">
    <div id={`${id}-empty`} class="flex flex-col items-center justify-center py-16 text-center">
      <svg class="mb-4 h-10 w-10 max-w-[40px] max-h-[40px] shrink-0 text-tech-text-muted/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <circle cx="9" cy="21" r="1" />
        <circle cx="20" cy="21" r="1" />
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
      </svg>
      <p class="text-sm text-tech-text-muted">Tu carrito está vacío</p>
    </div>
  </div>

  <!-- Template de item del carrito -->
  <template id="cart-item-tpl">
    <li class="flex gap-3 rounded-premium bg-tech-bg p-3">
      <img class="h-16 w-16 shrink-0 rounded-lg object-contain bg-white" loading="lazy" />
      <div class="flex min-w-0 flex-1 flex-col justify-center gap-1">
        <p class="js-cart-title truncate text-sm font-medium text-tech-text-primary"></p>
        <p class="js-cart-spec text-xs text-tech-text-muted"></p>
        <div class="flex items-center gap-2 pt-1">
          <button class="js-qty-down text-xs text-tech-text-muted hover:text-tech-text-primary">
            <svg style="width:16px;height:16px;" class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" y1="8" x2="12" y2="8"/></svg>
          </button>
          <span class="js-cart-qty min-w-[1.5ch] text-center text-sm font-medium text-tech-text-primary"></span>
          <button class="js-qty-up text-xs text-tech-text-muted hover:text-tech-text-primary">
            <svg style="width:16px;height:16px;" class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="4" x2="8" y2="12"/><line x1="4" y1="8" x2="12" y2="8"/></svg>
          </button>
          <span class="js-cart-subtotal ml-auto text-sm font-semibold text-tech-text-primary"></span>
          <button class="js-remove-item ml-1 text-tech-text-muted hover:text-red-500" aria-label="Eliminar">
            <svg style="width:16px;height:16px;" class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M2 4h12M5 4V2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 .5.5V4M3 4v9.5a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4"/></svg>
          </button>
        </div>
      </div>
    </li>
  </template>

  <!-- Safelist oculto: fuerza a Tailwind a generar todas las clases
       usadas en el script dinámico, incluso cuando aparecen dentro
       de literales de string JavaScript que el scanner podría omitir. -->
  <div aria-hidden="true" class="hidden h-4 w-4 scale-95 space-y-4 rounded-premium bg-tech-bg"></div>

  <div id={`${id}-footer`} class="hidden border-t border-tech-border px-5 py-4">
    <div class="flex items-center justify-between text-sm">
      <span class="text-tech-text-muted">Total</span>
      <span id={`${id}-total`} class="text-lg font-bold text-tech-text-primary"></span>
    </div>
    <button
      id={`${id}-checkout`}
      class="mt-3 w-full rounded-premium bg-tech-accent-blue px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:bg-tech-accent-blue/85 active:scale-[0.98] disabled:opacity-30 disabled:cursor-not-allowed disabled:active:scale-100"
      disabled
    >
      Agendar visita en persona
    </button>
  </div>
</aside>

<!-- Cal.com booking modal -->
<div
  id="cal-booking-overlay"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/80 backdrop-blur-md transition-all duration-300 opacity-0 pointer-events-none"
>
  <div
    id="cal-booking-card"
    class="relative w-full max-w-4xl h-[85vh] bg-[#121212] rounded-2xl border border-slate-800 overflow-hidden shadow-2xl transition-all duration-300 scale-95"
  >
    <button
      id="cal-booking-close"
      class="absolute top-3 right-3 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-black/60 text-white/60 hover:text-white hover:bg-black/80 transition-colors"
      aria-label="Cerrar calendario"
    >
      <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="4" x2="12" y2="12"/>
        <line x1="12" y1="4" x2="4" y2="12"/>
      </svg>
    </button>
    <iframe
      id="cal-booking-iframe"
      class="w-full h-full rounded-2xl"
      allowfullscreen
      loading="lazy"
      sandbox="allow-scripts allow-forms allow-popups allow-same-origin"
    ></iframe>
  </div>
</div>

<script>
import {
  $cartOpen,
  $cartState,
  closeCart,
  removeItem,
  updateQuantity,
} from '../stores/cart.store';
import { formatPrice } from '../utils';
import { buildCartNotes } from '../../checkout/services/cal.service';
import { renderCartList } from '../services/cart-renderer';
import { initItemEvents } from '../services/cart-events';
import { createCalBookingModal } from '../services/cart-calbooking';

const id = 'cart-drawer';

const overlay = document.getElementById(id + '-overlay');
const panel = document.getElementById(id + '-panel');
const itemsEl = document.getElementById(id + '-items');
const emptyEl = document.getElementById(id + '-empty');
const footerEl = document.getElementById(id + '-footer');
const totalEl = document.getElementById(id + '-total');
const countEl = document.getElementById(id + '-count');
const closeBtn = document.getElementById(id + '-close');
const checkoutBtn = document.getElementById(id + '-checkout');
const tpl = document.getElementById('cart-item-tpl') as HTMLTemplateElement | null;

const calBooking = createCalBookingModal();

$cartState.subscribe(function (state) {
  const items = state.items;
  const total = state.total;
  const count = state.count;

  if (countEl) {
    countEl.textContent = count > 0 ? '(' + count + ')' : '';
  }

  if (items.length === 0) {
    if (emptyEl) emptyEl.classList.remove('hidden');
    if (footerEl) footerEl.classList.add('hidden');
    setCheckoutEnabled(false);
    return;
  }

  if (emptyEl) emptyEl.classList.add('hidden');
  if (footerEl) footerEl.classList.remove('hidden');
  if (totalEl) totalEl.textContent = formatPrice(total);
  setCheckoutEnabled(true);

  renderCartList(items, itemsEl, tpl);
});

$cartOpen.subscribe(function (open) {
  if (overlay) {
    overlay.classList.toggle('opacity-0', !open);
    overlay.classList.toggle('pointer-events-none', !open);
  }
  if (panel) {
    panel.classList.toggle('translate-x-full', !open);
  }
  document.body.style.overflow = open ? 'hidden' : '';
});

function setCheckoutEnabled(enabled: boolean): void {
  if (!(checkoutBtn instanceof HTMLButtonElement)) return;
  checkoutBtn.disabled = !enabled;
}

if (closeBtn) {
  closeBtn.addEventListener('click', function () { closeCart(); });
}

if (checkoutBtn) {
  checkoutBtn.addEventListener('click', function () {
    const cart = $cartState.get();
    if (cart.items.length === 0) return;

    const notes = buildCartNotes(
      cart.items.map(function (item) {
        return {
          marca: item.product.marca ?? '',
          modelo: item.product.modelo ?? '',
          almacenamiento: item.product.almacenamiento ?? '',
          color: item.selectedColor,
          quantity: item.quantity,
        };
      }),
    );

    closeCart();
    calBooking.open(notes);
  });
}

if (overlay) {
  overlay.addEventListener('click', function () { closeCart(); });
}

document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    const calOpen = calBooking.overlay && !calBooking.overlay.classList.contains('pointer-events-none');
    if (calOpen) {
      calBooking.close();
    } else {
      closeCart();
    }
  }
});

initItemEvents(itemsEl, {
  removeItem,
  updateQuantity,
  getCurrentState: () => $cartState.get().items,
});
</script>
