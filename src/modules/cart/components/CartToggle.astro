---
export interface Props {
  id?: string;
}

const { id = 'cart-toggle' } = Astro.props;
---

<button
  id={id}
  class="relative flex h-9 w-9 items-center justify-center rounded-full bg-blue-600 text-white shadow-sm transition-colors hover:bg-blue-700"
  aria-label="Abrir carrito"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <circle cx="9" cy="21" r="1" />
    <circle cx="20" cy="21" r="1" />
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
  </svg>
  <span
    id={`${id}-badge`}
    class="absolute -right-1.5 -top-1.5 flex h-4 min-w-[16px] items-center justify-center rounded-full bg-red-500 px-0.5 text-[9px] font-bold text-white"
  >0</span>
</button>

<script>
import { $cartCount, openCart } from '../stores/cart.store';

var id = 'cart-toggle';
var button = document.getElementById(id);
var badge = document.getElementById(id + '-badge');

$cartCount.subscribe(function (count) {
  if (badge) {
    badge.textContent = String(count);
    badge.classList.toggle('hidden', count === 0);
  }
});

if (button) {
  button.addEventListener('click', function () { openCart(); });
}
</script>
