---
/**
 * CartToggle.astro
 * Responsabilidad: Botón flotante del carrito con badge de cantidad.
 * SSR: renderiza el HTML estático.
 * Cliente: el <script> se suscribe a nanostores para el contador.
 *
 * El componente PADRE (BaseLayout) aplica client:load.
 */

export interface Props {
  id?: string;
}

const { id = 'cart-toggle' } = Astro.props;
---

<button
  id={id}
  class="fixed bottom-6 right-6 z-30 flex h-12 w-12 items-center justify-center rounded-full bg-tech-accent-blue text-white shadow-lg transition-all duration-200 hover:bg-tech-accent-blue/85 active:scale-95"
  aria-label="Abrir carrito"
>
  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <circle cx="9" cy="21" r="1" />
    <circle cx="20" cy="21" r="1" />
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
  </svg>
  <span
    id={`${id}-badge`}
    class="absolute -right-1 -top-1 flex h-5 min-w-[20px] items-center justify-center rounded-full bg-red-500 px-1 text-[10px] font-bold text-white"
  >0</span>
</button>

<script>
import { $cartCount, openCart } from '../stores/cart.store';

var id = 'cart-toggle';
var button = document.getElementById(id);
var badge = document.getElementById(id + '-badge');

$cartCount.subscribe(function (count) {
  if (badge) {
    badge.textContent = String(count);
    badge.classList.toggle('hidden', count === 0);
  }
});

if (button) {
  button.addEventListener('click', function () { openCart(); });
}
</script>
