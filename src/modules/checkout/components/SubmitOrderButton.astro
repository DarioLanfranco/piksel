---
export interface Props {
  id?: string;
  label?: string;
}

const { id = 'submit-order', label = 'Agendar visita en persona' } = Astro.props;

const CSS = {
  button: [
    'w-full rounded-premium px-6 py-3.5 text-sm font-semibold',
    'transition-all duration-200',
    'bg-tech-accent-blue text-white',
    'hover:bg-tech-accent-blue/85 active:scale-[0.98]',
    'disabled:opacity-30 disabled:cursor-not-allowed disabled:active:scale-100',
    'inline-flex items-center justify-center gap-2',
  ].join(' '),
} as const;
---

<button
  id={`${id}-btn`}
  class={CSS.button}
  disabled
  type="button"
>
  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
    <line x1="16" y1="2" x2="16" y2="6" />
    <line x1="8" y1="2" x2="8" y2="6" />
    <line x1="3" y1="10" x2="21" y2="10" />
    <circle cx="12" cy="16" r="1" />
  </svg>
  <span>{label}</span>
</button>

<script>
import './SubmitOrderButton.client';
</script>
