---
/**
 * CheckoutForm.astro — Formulario de facturación defensivo
 *
 * Responsabilidad: Recolectar datos del comprador y resumen del carrito
 * en una isla reactiva conectada a nanostores persistentes.
 *
 * ══════════════════════════════════════════════════════════
 *  ARQUITECTURA DE PERSISTENCIA
 *  ──────────────────────────
 *  $customer es un persistentAtom que escribe a localStorage
 *  en cada cambio. Esto significa que si el usuario:
 *    a) Refresca la página  → los datos se restauran
 *    b) Cierra el navegador → los datos sobreviven
 *    c) Vuelve del catálogo → los datos están intactos
 *
 *  La suscripción bidireccional funciona así:
 *    input.value ──(oninput)──> updateCustomerData() ──> $customer.set()
 *    $customer ──(subscribe)──> if (input.value !== data.x) omitir asignación
 *
 *  El guard "input.value !== data.x" evita que el cursor
 *  salte al final del input mientras el usuario escribe,
 *  problema clásico de stores reactivas.
 * ══════════════════════════════════════════════════════════
 */

export interface Props {
  id?: string;
}

import SubmitOrderButton from './SubmitOrderButton.astro';

const { id = 'checkout-form' } = Astro.props;

const CSS = {
  fieldset: 'space-y-5',
  label: 'block text-sm font-medium text-tech-text-primary',
  input: [
    'mt-1 block w-full rounded-premium border border-tech-border',
    'bg-tech-card px-4 py-2.5 text-sm text-tech-text-primary',
    'placeholder:text-tech-text-muted/50',
    'transition-shadow duration-200',
    'focus:border-tech-accent-blue focus:outline-none focus:ring-2 focus:ring-tech-accent-blue/20',
  ].join(' '),
  radioGroup: 'mt-2 grid grid-cols-2 gap-3',
  radioLabel: [
    'flex cursor-pointer items-center justify-center gap-2',
    'rounded-premium border border-tech-border px-4 py-3',
    'text-sm font-medium text-tech-text-primary',
    'transition-all duration-150',
    'hover:border-tech-accent-blue/50 hover:bg-tech-accent-blue/5',
    'has-[input:checked]:border-tech-accent-blue has-[input:checked]:bg-tech-accent-blue/10',
    'has-[input:checked]:ring-1 has-[input:checked]:ring-tech-accent-blue/30',
  ].join(' '),
  radioInput: 'sr-only',
  summaryCard: [
    'rounded-premium border border-tech-border bg-tech-card p-4',
    'shadow-clean',
  ].join(' '),
  submitBtn: [
    'w-full rounded-premium px-6 py-3.5 text-sm font-semibold',
    'transition-all duration-200',
    'bg-tech-accent-blue text-white',
    'hover:bg-tech-accent-blue/85 active:scale-[0.98]',
    'disabled:opacity-30 disabled:cursor-not-allowed disabled:active:scale-100',
  ].join(' '),
} as const;

const METODOS_ENTREGA = [
  { value: 'retiro', label: 'Retiro en local', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { value: 'envio', label: 'Envío a domicilio', icon: 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M9 13h10l2-5H5l1 3h3z' },
] as const;

const METODOS_PAGO = [
  { value: 'efectivo_usd', label: 'Efectivo USD', subtitle: '5% descuento' },
  { value: 'transferencia_ars', label: 'Transferencia ARS', subtitle: 'Sin interés' },
  { value: 'financiado', label: 'Financiado', subtitle: '3 a 12 cuotas' },
] as const;
---

<div id={id} class="grid gap-8 lg:grid-cols-[1fr_380px]">
  <!-- ════════════════════════════════════
       COLUMNA PRINCIPAL — Formulario
       ════════════════════════════════════ -->
  <div class={CSS.summaryCard}>
    <h2 class="text-base font-semibold text-tech-text-primary">Datos de facturación</h2>

    <form id={`${id}-form`} class="mt-5 space-y-5" novalidate>
      <!-- Fila: Nombre + Apellido -->
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for={`${id}-nombre`} class={CSS.label}>Nombre</label>
            <input
            id={`${id}-nombre`}
            name="nombre"
            class={CSS.input}
            type="text"
            inputmode="text"
            autocomplete="given-name"
            placeholder="Juan"
            required
          />
        </div>
        <div>
          <label for={`${id}-apellido`} class={CSS.label}>Apellido</label>
            <input
            id={`${id}-apellido`}
            name="apellido"
            class={CSS.input}
            type="text"
            inputmode="text"
            autocomplete="family-name"
            placeholder="Pérez"
            required
          />
        </div>
      </div>

      <!-- Teléfono con prefijo -->
      <div>
        <label for={`${id}-telefono`} class={CSS.label}>Teléfono</label>
        <div class="mt-1 flex">
          <span
            class="inline-flex items-center rounded-l-premium border border-r-0 border-tech-border bg-tech-bg px-3 text-sm text-tech-text-muted select-none"
          >+54 9</span>
          <input
            id={`${id}-telefono`}
            name="telefono"
            class={`${CSS.input} rounded-l-none mt-0`}
            type="tel"
            inputmode="numeric"
            autocomplete="tel-national"
            placeholder="358 123 4567"
            required
          />
        </div>
      </div>

      <!-- Método de entrega -->
      <fieldset>
        <legend class={CSS.label}>Método de entrega</legend>
        <div class={CSS.radioGroup}>
          {METODOS_ENTREGA.map((m) => (
            <label class={CSS.radioLabel}>
              <input type="radio" name="metodo-entrega" value={m.value} class={CSS.radioInput} />
              <svg class="h-4 w-4 shrink-0 text-tech-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d={m.icon} />
              </svg>
              {m.label}
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Método de pago -->
      <fieldset>
        <legend class={CSS.label}>Método de pago</legend>
        <div class="mt-2 grid gap-3 sm:grid-cols-3">
          {METODOS_PAGO.map((m) => (
            <label class={CSS.radioLabel}>
              <input type="radio" name="metodo-pago" value={m.value} class={CSS.radioInput} />
              <div class="text-center">
                <div class="text-sm font-medium">{m.label}</div>
                <div class="text-[11px] font-normal text-tech-text-muted">{m.subtitle}</div>
              </div>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Feedback de validación -->
      <p id={`${id}-hint`} class="text-xs text-tech-text-muted" aria-live="polite">
        Completá nombre, apellido y teléfono para continuar.
      </p>
    </form>
  </div>

  <!-- ════════════════════════════════════
       COLUMNA SECUNDARIA — Resumen del carrito
       ════════════════════════════════════ -->
  <div class="flex flex-col gap-4">
    <div class={CSS.summaryCard}>
      <h2 class="text-base font-semibold text-tech-text-primary">Tu pedido</h2>
      <div id={`${id}-items`} class="mt-4 space-y-1">
        <p class="py-6 text-center text-sm text-tech-text-muted">Cargando carrito…</p>
      </div>
      <div id={`${id}-total`} class="mt-4 hidden border-t border-tech-border pt-4">
        <div class="flex items-center justify-between text-sm">
          <span class="text-tech-text-muted">Total</span>
          <span id={`${id}-total-value`} class="text-lg font-bold text-tech-text-primary"></span>
        </div>
      </div>
    </div>

    <SubmitOrderButton />
  </div>
</div>

<script>
import './CheckoutForm.client';
</script>
