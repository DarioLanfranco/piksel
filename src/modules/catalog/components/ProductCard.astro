---
import type { Product } from '../../../domain/product/product.entity';
import { formatPrice } from '../../cart/utils';
import { serializeProduct } from '../../product/services/product.serializer';
import { ProductMapper } from '../../../infrastructure/sheets/product.mapper';
import { getColorHex } from '../../product/services/product-colors';

export interface Props {
  product: Product;
}

const { product } = Astro.props;

const slug = ProductMapper.generateSlug(product);

const priceFormatted = formatPrice(product.precio);

const colorHex = getColorHex(product.colorOficial);
const productJson = JSON.stringify(serializeProduct(product));
---

<article data-product-id={product.id} class="flex flex-col justify-between rounded-2xl border border-tech-border bg-tech-card p-5 shadow-clean transition-shadow duration-200 hover:shadow-md">
  <!-- Badge -->
  {product.stock && (
    <span class="mb-3 inline-block w-fit rounded-full bg-tech-accent-green/10 px-2.5 py-0.5 text-[11px] font-semibold text-tech-accent-green">
      En stock
    </span>
  )}

  <!-- Image -->
  <a href={`${import.meta.env.BASE_URL}/productos/${slug}`} class="no-underline">
    <img
      src={product.fotosGaleria[0]}
      alt={`${product.marca} ${product.modelo} ${product.almacenamiento}`}
      class="mx-auto mb-4 block h-48 object-contain"
      loading="lazy"
      decoding="async"
    />
  </a>

  <!-- Info -->
  <div class="flex flex-col gap-1">
    <p class="text-[11px] font-semibold uppercase tracking-wide text-tech-text-muted">
      {product.marca}
    </p>
    <h3 class="text-sm font-semibold leading-snug text-tech-text-primary">
      <a href={`${import.meta.env.BASE_URL}/productos/${slug}`} class="no-underline text-inherit">
        {product.modelo}
      </a>
    </h3>

    <!-- Specs con SVGs -->
    <ul class="mt-1.5 list-none space-y-1">
      <li class="flex items-center gap-1.5 text-xs text-tech-text-muted">
        <svg class="inline-block h-5 w-5 min-w-[20px] min-h-[20px] max-w-[24px] max-h-[24px] shrink-0 text-tech-text-muted" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <rect x="1" y="3" width="14" height="10" rx="1.5" />
          <circle cx="8" cy="8" r="2.5" />
          <line x1="8" y1="5.5" x2="8" y2="3" />
        </svg>
        <span class="truncate">{product.procesador}</span>
      </li>
      <li class="flex items-center gap-1.5 text-xs text-tech-text-muted">
        <svg class="inline-block h-5 w-5 min-w-[20px] min-h-[20px] max-w-[24px] max-h-[24px] shrink-0 text-tech-text-muted" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <circle cx="8" cy="7" r="3" />
          <rect x="3" y="8" width="10" height="5" rx="1" />
          <circle cx="5.5" cy="6" r="1" fill="currentColor" stroke="none" />
          <circle cx="10.5" cy="6" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span class="truncate">{product.camaras}</span>
      </li>
      <li class="flex items-center gap-1.5 text-xs text-tech-text-muted">
        <svg class="inline-block h-5 w-5 min-w-[20px] min-h-[20px] max-w-[24px] max-h-[24px] shrink-0 text-tech-text-muted" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <rect x="2" y="2" width="12" height="12" rx="1.5" />
          <line x1="2" y1="6" x2="14" y2="6" />
          <line x1="8" y1="6" x2="8" y2="14" />
        </svg>
        <span>{product.almacenamiento}</span>
      </li>
    </ul>

    <!-- Color -->
    <div class="mt-1 flex items-center gap-1.5 text-xs text-tech-text-muted">
      <span
        class="inline-block h-3 w-3 shrink-0 rounded-full ring-1 ring-inset ring-black/10"
        style={`background-color: ${colorHex}`}
      />
      {product.colorOficial}
    </div>
  </div>

  <!-- Price + Add button -->
  <div class="mt-4 flex items-center justify-between gap-2">
    <span class="text-base font-bold text-tech-text-primary">
      {priceFormatted}
    </span>
    <button
      class="js-add-to-cart flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full bg-tech-accent-blue text-lg font-bold text-white shadow-sm transition-colors duration-200 hover:bg-tech-accent-blue/85 focus:outline-none focus:ring-2 focus:ring-tech-accent-blue focus:ring-offset-2"
      data-product={productJson}
      aria-label={`Agregar ${product.marca} ${product.modelo} al carrito`}
    >
      +
    </button>
  </div>
</article>

