---
import type { Product } from '../../../domain/product/product.entity';
import { SheetsProductRepository } from '../../../infrastructure/sheets/sheets.repository';
import ProductCard from './ProductCard.astro';

const repository = new SheetsProductRepository();
let products: Product[] = [];

try {
  products = await repository.findAll();
} catch (error) {
  console.error('[ProductGrid] Error al cargar el catálogo:', (error as Error).message);
}
---

{products.length === 0 ? (
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <svg class="mb-5 h-12 w-12 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
      <rect x="4" y="2" width="16" height="20" rx="3" />
      <line x1="9" y1="18" x2="15" y2="18" />
      <line x1="12" y1="2" x2="12" y2="6" />
    </svg>
    <h2 class="text-xl font-semibold text-slate-900">
      Catálogo vacío
    </h2>
    <p class="mt-1.5 text-sm text-slate-500">
      No se encontraron celulares disponibles en este momento.
    </p>
  </div>
) : (
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {products.map((product) => (
      <ProductCard product={product} />
    ))}
  </div>
)}
