---
import type { Product } from '../../../domain/product/product.entity';
import ProductCard from './ProductCard.astro';
import { serializeProduct } from '../../product/services/product.serializer';

export interface Props {
  products: Product[];
}

const { products } = Astro.props;

const productsJson = JSON.stringify(products.map(serializeProduct));
---

<div
  id="product-grid-container"
  data-products={productsJson}
>
  <div id="product-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {products.map(product => (
      <ProductCard product={product} />
    ))}
  </div>

  <div id="product-grid-empty" class="hidden flex-col items-center justify-center py-24 text-center">
    <svg class="mb-5 h-12 w-12 text-tech-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
      <rect x="4" y="2" width="16" height="20" rx="3" />
      <line x1="9" y1="18" x2="15" y2="18" />
      <line x1="12" y1="2" x2="12" y2="6" />
    </svg>
    <h2 class="text-xl font-semibold text-tech-text-primary">
      Sin resultados
    </h2>
    <p class="mt-1.5 text-sm text-tech-text-muted">
      No se encontraron celulares que coincidan con tu búsqueda.
    </p>
  </div>
</div>

<script>
import { setProductList, $filteredProducts } from '../stores/catalog.store';

const container = document.getElementById('product-grid-container');
const grid = document.getElementById('product-grid');
const empty = document.getElementById('product-grid-empty');

if (container) {
  const raw = container.getAttribute('data-products');
  if (raw) {
    try {
      setProductList(JSON.parse(raw));
    } catch {
      /* grid renders SSR fallback */
    }
  }
}

function updateGrid(ids: string[]): void {
  if (!grid || !empty) return;

  const cards = grid.querySelectorAll('[data-product-id]');
  let visibleCount = 0;

  for (let i = 0; i < cards.length; i++) {
    const card = cards[i];
    const id = card.getAttribute('data-product-id');
    const match = ids.length === 0 || ids.includes(id ?? '');
    card.classList.toggle('hidden', !match);
    if (match) visibleCount++;
  }

  empty.classList.toggle('hidden', visibleCount > 0);
}

$filteredProducts.subscribe(function (filtered) {
  updateGrid(filtered.map(p => p.id));
});
</script>
