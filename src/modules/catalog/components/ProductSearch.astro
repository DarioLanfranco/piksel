---
---

<div class="relative w-full max-w-md">
  <svg
    class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-tech-text-muted"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="11" cy="11" r="8" />
    <line x1="21" y1="21" x2="16.65" y2="16.65" />
  </svg>
  <input
    id="product-search-input"
    type="text"
    placeholder="Buscar marca o modelo..."
    class="w-full rounded-xl border bg-zinc-100 py-2.5 pl-10 pr-4 text-sm text-zinc-900 placeholder-zinc-500 transition-all duration-200 focus:border-[#FF7F11] focus:outline-none focus:ring-1 focus:ring-[#FF7F11] dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100 dark:placeholder-zinc-400"
  />
</div>

<script>
import { setSearchQuery } from '../stores/catalog.store';

const input = document.getElementById('product-search-input');

if (input instanceof HTMLInputElement) {
  input.addEventListener('input', function () {
    setSearchQuery(this.value);
  });
}
</script>
