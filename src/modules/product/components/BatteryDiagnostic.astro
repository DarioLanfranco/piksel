---
export interface Props {
  bateriaCondicion: number | null;
  bateriaCiclos: number | null;
  estadoComponente: string | null;
}

const { bateriaCondicion, bateriaCiclos, estadoComponente } = Astro.props;

const hasData =
  bateriaCondicion !== null ||
  bateriaCiclos !== null ||
  (estadoComponente !== null && estadoComponente.length > 0);

function batteryColors(condicion: number): { stroke: string; text: string } {
  if (condicion >= 90) return { stroke: 'stroke-emerald-500', text: 'text-emerald-700 dark:text-emerald-400' };
  if (condicion >= 80) return { stroke: 'stroke-amber-500', text: 'text-amber-700 dark:text-amber-400' };
  return { stroke: 'stroke-red-500', text: 'text-red-700 dark:text-red-400' };
}

const batteryColor = bateriaCondicion !== null ? batteryColors(bateriaCondicion) : null;

let badgeClass = '';
let badgeLabel = '';

if (estadoComponente && estadoComponente.length > 0) {
  const lower = estadoComponente.toLowerCase().trim();
  if (lower === 'original verificado' || lower === 'verificado') {
    badgeClass = 'bg-green-50 text-green-700 border-green-200 dark:bg-transparent dark:text-green-400 dark:border-green-500/30';
  } else if (lower === 'nuevo / sellado' || lower === '0km' || lower.startsWith('nuevo ')) {
    badgeClass = 'bg-blue-50 text-blue-700 border-blue-200 dark:bg-transparent dark:text-blue-400 dark:border-blue-500/30';
  } else if (lower.startsWith('reemplazado') || lower === 'reparado') {
    badgeClass = 'bg-amber-50 text-amber-700 border-amber-200 dark:bg-transparent dark:text-amber-400 dark:border-amber-500/30';
  } else {
    badgeClass = 'bg-zinc-50 text-zinc-600 border-zinc-200 dark:bg-transparent dark:text-zinc-400 dark:border-zinc-500/30';
  }
  badgeLabel = estadoComponente;
}

const R = 48;
const SVG_SIZE = 120;
const CIRCUMFERENCE = 2 * Math.PI * R;
const offset = bateriaCondicion !== null
  ? CIRCUMFERENCE - (CIRCUMFERENCE * Math.min(Math.max(bateriaCondicion, 0), 100) / 100)
  : CIRCUMFERENCE;

const wearPercent = bateriaCiclos !== null
  ? Math.min(Math.round(bateriaCiclos / 800 * 100), 100)
  : 0;

const wearBarClass =
  wearPercent <= 30 ? 'bg-emerald-500' :
  wearPercent <= 60 ? 'bg-amber-500' :
  'bg-red-500';
---

{
  !hasData ? (
    <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5 text-center dark:border-slate-800 dark:bg-slate-950/40">
      <div class="flex items-center justify-center gap-3 py-8">
        <svg class="h-8 w-8 shrink-0 text-tech-accent-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 7V4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v3" />
          <path d="M4 7h16v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7z" />
          <path d="M9 12h6" />
        </svg>
        <div class="text-left">
          <p class="text-sm font-medium text-tech-text-primary">Equipo 0km</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400">Batería al 100% de fábrica</p>
        </div>
      </div>
    </div>
  ) : (
    <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5 dark:border-slate-800 dark:bg-slate-950/40">
      <!-- Header -->
      <div class="mb-5 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 shrink-0 text-tech-accent-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 7V4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v3" />
            <path d="M4 7h16v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7z" />
            <path d="M9 12h6" />
          </svg>
          <span class="text-sm font-semibold text-zinc-900 dark:text-white">Diagnóstico de Hardware</span>
        </div>
        <span class="flex items-center gap-1.5 text-[11px] text-zinc-500 dark:text-zinc-400">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
          </span>
          Estado: En línea
        </span>
      </div>

      <!-- SVG Ring + Stats -->
      <div class="flex flex-col items-center gap-5 sm:flex-row sm:items-start sm:gap-6">
        <!-- Anillo SVG -->
        {bateriaCondicion !== null ? (
          <div class="relative shrink-0">
            <svg class="h-[120px] w-[120px] -rotate-90" viewBox={`0 0 ${SVG_SIZE} ${SVG_SIZE}`}>
              <circle
                cx={SVG_SIZE / 2}
                cy={SVG_SIZE / 2}
                r={R}
                fill="none"
                stroke="currentColor"
                stroke-width="6"
                class="text-zinc-200 dark:text-slate-800"
              />
              <circle
                cx={SVG_SIZE / 2}
                cy={SVG_SIZE / 2}
                r={R}
                fill="none"
                stroke-width="6"
                stroke-linecap="round"
                stroke-dasharray={CIRCUMFERENCE}
                stroke-dashoffset={offset}
                class={`transition-all duration-700 ${batteryColor?.stroke ?? ''}`}
              />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class={`text-2xl font-bold leading-none tracking-tight ${batteryColor?.text ?? ''}`}>
                {bateriaCondicion}<span class="text-sm font-normal">%</span>
              </span>
              <span class="mt-1 text-[10px] font-medium text-zinc-500 dark:text-zinc-400">Capacidad máxima</span>
            </div>
          </div>
        ) : null}

        <!-- Datos técnicos -->
        <div class="flex w-full flex-col gap-4">
          <!-- Ciclos de carga -->
          {bateriaCiclos !== null ? (
            <div>
              <div class="mb-1.5 flex items-baseline justify-between">
                <span class="text-xs text-zinc-500 dark:text-zinc-400">Ciclos de carga</span>
                <span class="text-sm font-semibold text-tech-text-primary">{bateriaCiclos}</span>
              </div>
              <div class="h-1.5 w-full overflow-hidden rounded-full bg-zinc-200 dark:bg-slate-800">
                <div
                  class={`h-full rounded-full transition-all duration-500 ${wearBarClass}`}
                  style={`width: ${wearPercent}%`}
                ></div>
              </div>
              <span class="mt-0.5 block text-right text-[10px] text-zinc-500 dark:text-zinc-400">
                {wearPercent}% de desgaste estimado
              </span>
            </div>
          ) : null}

          <!-- Condición del Componente -->
          {badgeLabel.length > 0 ? (
            <div>
              <span class="mb-1.5 block text-xs text-zinc-500 dark:text-zinc-400">Condición del Componente</span>
              <span class={`inline-block rounded-full border px-3 py-1 text-xs font-medium ${badgeClass}`}>
                {badgeLabel}
              </span>
            </div>
          ) : null}
        </div>
      </div>
    </div>
  )
}
