---
export interface Props {
  modelUrl: string | null | undefined;
  posterUrl?: string;
  alt?: string;
}

const { modelUrl, posterUrl, alt = 'Modelo 3D del teléfono' } = Astro.props;

const rawUrl = modelUrl?.trim() ?? '';
const isGlb = rawUrl.length > 0 && /\.glb([?#]|$)/i.test(rawUrl);
if (!isGlb) return null;
---

<div
  class="group relative overflow-hidden rounded-premium border border-tech-border bg-tech-surface-inverse shadow-clean"
  aria-label="Visor 3D interactivo"
>
  <model-viewer
    class="h-[420px] w-full sm:h-[480px]"
    src={rawUrl}
    alt={alt}
    loading="lazy"
    camera-controls
    auto-rotate
    auto-rotate-delay="1000"
    rotation-per-second="30deg"
    shadow-intensity="1.5"
    shadow-softness="0.6"
    exposure="1"
    environment-image="neutral"
    tone-mapping="commerce"
    ar
    ar-modes="webxr scene-viewer quick-look"
    ar-scale="fixed"
    poster={posterUrl ?? undefined}
  >
  </model-viewer>

  <div class="pointer-events-none absolute bottom-3 left-3 flex items-center gap-1.5 rounded-full bg-black/50 px-2.5 py-1 text-[11px] font-medium text-white/80 shadow-sm backdrop-blur transition-opacity duration-300 group-hover:opacity-0">
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7l10 5 10-5-10-5z" />
      <path d="M2 17l10 5 10-5" />
      <path d="M2 12l10 5 10-5" />
    </svg>
    3D Interactivo
  </div>

  <div class="pointer-events-none absolute bottom-3 right-3 flex items-center gap-1 rounded-full bg-black/50 px-2 py-1 text-[10px] font-medium text-white/60 shadow-sm backdrop-blur transition-opacity duration-300 group-hover:opacity-0">
    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.66 0 3-4 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4-3-9s1.34-9 3-9m-9 9a9 9 0 019-9" />
    </svg>
    Arrastra
  </div>
</div>

<script is:inline>
(function () {
  'use strict';

  var viewer = document.querySelector('model-viewer');
  if (!viewer) return;

  function getModelUrl() {
    return viewer.getAttribute('src') || '';
  }

  function diagnoseModelError(url) {
    console.warn('[ProductViewer3D] \u274c Error al cargar el modelo 3D:', url);

    fetch(url, { method: 'HEAD', mode: 'cors' })
      .then(function (res) {
        if (res.ok) {
          console.log('[ProductViewer3D] \u2705 La URL responde OK (HTTP ' + res.status + ') \u2014 el error puede ser interno del parser 3D (archivo .glb corrupto o incompatible).');
        } else if (res.status === 404) {
          console.warn('[ProductViewer3D] \u26a0\ufe0f HTTP ' + res.status + ' (No encontrado) \u2014 el archivo .glb no existe en la URL provista.');
        } else {
          console.warn('[ProductViewer3D] \u26a0\ufe0f HTTP ' + res.status + ' ' + res.statusText + ' \u2014 el servidor rechaz\u00f3 la petici\u00f3n. Verific\u00e1 que el archivo .glb exista y sea accesible.');
        }
      })
      .catch(function () {
        console.warn('[ProductViewer3D] \ud83d\udeab Error de RED o CORS bloqueado \u2014 no se puede acceder a:', url);
        console.warn('[ProductViewer3D] Posible soluci\u00f3n: el servidor donde est\u00e1n alojados los .glb debe incluir estos headers CORS:');
        console.warn('[ProductViewer3D]   Access-Control-Allow-Origin: https://' + location.hostname);
        console.warn('[ProductViewer3D]   Access-Control-Allow-Methods: GET, HEAD');
        console.warn('[ProductViewer3D]   Access-Control-Allow-Headers: Content-Type');
      });
  }

  if (customElements.get('model-viewer')) {
    attachEvents();
  } else {
    var script = document.createElement('script');
    script.type = 'module';
    script.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js';
    script.async = true;
    script.crossOrigin = 'anonymous';

    script.addEventListener('load', function () {
      attachEvents();
    });

    script.addEventListener('error', function () {
      console.warn('[ProductViewer3D] \ud83d\udee1\ufe0f No se pudo descargar la librer\u00eda model-viewer desde el CDN.');
      diagnoseModelError(getModelUrl());
    });

    document.head.appendChild(script);
  }

  function attachEvents() {
    if (!viewer) return;

    viewer.addEventListener('error', function () {
      diagnoseModelError(getModelUrl());
    });

    viewer.addEventListener('load', function () {
      console.log('[ProductViewer3D] \u2705 Modelo 3D cargado correctamente:', getModelUrl());
    });
  }
})();
</script>
