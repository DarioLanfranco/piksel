---
export interface Props {
  premiumMarca: string;
  premiumModelo: string;
  premiumCamaraMp: number;
  premiumBateriaHoras: number | null;
  premiumLanzamientoAnio: number | null;
}

const {
  premiumMarca,
  premiumModelo,
  premiumCamaraMp,
  premiumBateriaHoras,
  premiumLanzamientoAnio,
} = Astro.props;
---

<div
  id="smart-compare-root"
  class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5 dark:border-slate-800 dark:bg-slate-950/40"
  data-premium-camara={premiumCamaraMp}
  data-premium-bateria={premiumBateriaHoras ?? ''}
  data-premium-anio={premiumLanzamientoAnio ?? ''}
  data-premium-marca={premiumMarca}
  data-premium-modelo={premiumModelo}
>
  <div class="mb-4 flex items-center gap-2">
    <svg class="h-4 w-4 shrink-0 text-tech-accent-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M16 16v1a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2m5.66 0H14a2 2 0 0 1 2 2v3.34l1 1L23 7v10l-5.34-5.34" />
      <path d="M18 2l4 4-4 4" />
      <path d="M6 12l4-4 4 4" />
    </svg>
    <span class="text-sm font-semibold text-tech-text-primary">Comparar con tu equipo actual</span>
  </div>

  <select
    id="smart-compare-select"
    class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-sm text-zinc-900 outline-none transition-colors focus:border-[#FF7F11] dark:border-slate-700 dark:bg-slate-900 dark:text-zinc-100"
  >
    <option value="">Seleccioná tu equipo actual</option>
  </select>

  <div id="smart-compare-results" class="mt-5 hidden"></div>
</div>

<script>
import marketModels from '../../../data/marketModels.json';
import { computeDiff } from '../services/compute-diff';
import type { DiffResult } from '../services/compute-diff';

function escaped(s: string): string {
  const div = document.createElement('div');
  div.appendChild(document.createTextNode(s));
  return div.innerHTML;
}

function svgHTML(children: string): string {
  return '<svg viewBox="0 0 24 24" class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5">' + children + '</svg>';
}

function iconCamara(): string {
  return svgHTML('<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>');
}
function iconBateria(): string {
  return svgHTML('<rect x="1" y="6" width="18" height="12" rx="2"/><path d="M23 10v4"/><path d="M7 10l2 3 3-4"/>');
}
function iconCalendario(): string {
  return svgHTML('<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>');
}
function iconCapa(): string {
  return svgHTML('<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>');
}

function diffHTML(diff: DiffResult): string {
  if (!diff.diffLabel) return '';
  var cls = 'text-[10px] font-medium ' + (diff.isGain ? 'text-emerald-700 dark:text-emerald-400' : 'text-red-700 dark:text-red-400');
  return '<span class="' + cls + '">' + escaped(diff.diffLabel) + '</span>';
}

function buildRowHTML(
  svg: string,
  label: string,
  marketVal: number | null,
  premiumVal: number | null,
  fmt: (v: number) => string,
  higherIsBetter: boolean,
): string | null {
  if (marketVal === null && premiumVal === null) return null;

  var marketStr = marketVal !== null ? fmt(marketVal) : '\u2014';
  var premiumStr = premiumVal !== null ? fmt(premiumVal) : '\u2014';

  var diff: DiffResult = { direction: '\u2192', diffLabel: '', isGain: false };
  var arrowCls = 'text-zinc-400 dark:text-slate-400';

  if (marketVal !== null && premiumVal !== null && marketVal !== premiumVal) {
    diff = computeDiff(premiumVal, marketVal, higherIsBetter);
    arrowCls = diff.isGain ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-600 dark:text-red-400';
  }

  var extra = diffHTML(diff);

  return '<div class="flex items-center justify-between rounded-lg bg-zinc-100 px-3.5 py-2.5 dark:bg-slate-900/60">'
    + '<div class="flex items-center gap-2 min-w-0">'
    + '<span class="shrink-0 text-zinc-400 dark:text-slate-500">' + svg + '</span>'
    + '<span class="text-xs font-medium text-zinc-600 dark:text-slate-400">' + escaped(label) + '</span>'
    + '</div>'
    + '<div class="flex items-center gap-2 shrink-0">'
    + '<span class="text-xs text-zinc-500 dark:text-slate-400">' + escaped(marketStr) + '</span>'
    + '<span class="text-xs ' + arrowCls + '">' + diff.direction + '</span>'
    + '<span class="text-xs font-semibold text-zinc-900 dark:text-white">' + escaped(premiumStr) + '</span>'
    + (extra ? extra : '')
    + '</div>'
    + '</div>';
}

var root = document.getElementById('smart-compare-root');
var select = document.getElementById('smart-compare-select');
var results = document.getElementById('smart-compare-results');

if (root && select instanceof HTMLSelectElement && results) {
  var premiumCamara = parseInt(root.getAttribute('data-premium-camara') ?? '0', 10);
  var premiumBateriaRaw = root.getAttribute('data-premium-bateria') ?? '';
  var premiumBateria = premiumBateriaRaw.length > 0 ? parseInt(premiumBateriaRaw, 10) : null;
  var premiumAnioRaw = root.getAttribute('data-premium-anio') ?? '';
  var premiumAnio = premiumAnioRaw.length > 0 ? parseInt(premiumAnioRaw, 10) : null;
  var premiumMarca = root.getAttribute('data-premium-marca') ?? '';
  var premiumModelo = root.getAttribute('data-premium-modelo') ?? '';

  var brands = Object.keys(marketModels) as Array<keyof typeof marketModels>;
  var fragment = document.createDocumentFragment();
  for (var b = 0; b < brands.length; b++) {
    var brand = brands[b];
    var models = marketModels[brand];
    var group = document.createElement('optgroup');
    group.label = brand;
    for (var m = 0; m < models.length; m++) {
      var entry = models[m];
      var opt = document.createElement('option');
      opt.value = entry.modelo;
      opt.setAttribute('data-brand', brand);
      opt.setAttribute('data-camara', String(entry.camara_mp_numero));
      opt.setAttribute('data-bateria', String(entry.bateria_horas_numero));
      opt.setAttribute('data-anio', String(entry.lanzamiento_anio));
      opt.textContent = brand + ' ' + entry.modelo;
      group.appendChild(opt);
    }
    fragment.appendChild(group);
  }
  select.appendChild(fragment);

  function fmtCamara(v: number): string { return v + ' MP'; }
  function fmtBateria(v: number): string { return v + ' h'; }
  function fmtAnio(v: number): string { return String(v); }

  select.addEventListener('change', function () {
    if (!(select instanceof HTMLSelectElement) || !results) return;
    var idx = select.selectedIndex;
    if (idx < 1 || !select.options[idx]) {
      results.classList.add('hidden');
      return;
    }

    results.innerHTML = '';
    results.classList.remove('hidden');

    var opt = select.options[idx];
    var brand = opt.getAttribute('data-brand') ?? '';
    var marketCamara = parseInt(opt.getAttribute('data-camara') ?? '0', 10);
    var marketBateria = parseInt(opt.getAttribute('data-bateria') ?? '0', 10);
    var marketAnio = parseInt(opt.getAttribute('data-anio') ?? '0', 10);

    var headerHTML =
      '<div class="mb-3 flex items-center gap-2 border-b border-zinc-200 pb-2 text-xs text-zinc-500 dark:border-slate-800 dark:text-slate-500">'
      + '<span class="flex items-center">' + iconCapa() + '</span>'
      + '<span>Tu ' + escaped(brand) + ' <strong class="text-zinc-700 dark:text-slate-300">' + escaped(opt.value) + '</strong>'
      + ' \u2192 ' + escaped(premiumMarca) + ' <strong class="text-zinc-700 dark:text-slate-300">' + escaped(premiumModelo) + '</strong></span>'
      + '</div>';

    results.insertAdjacentHTML('beforeend', headerHTML);

    var rowCam = buildRowHTML(iconCamara(), 'C\u00e1mara principal', marketCamara, premiumCamara, fmtCamara, true);
    if (rowCam) results.insertAdjacentHTML('beforeend', rowCam);

    if (premiumBateria !== null) {
      var rowBat = buildRowHTML(iconBateria(), 'Bater\u00eda (horas)', marketBateria, premiumBateria, fmtBateria, true);
      if (rowBat) results.insertAdjacentHTML('beforeend', rowBat);
    }

    if (premiumAnio !== null) {
      var rowYear = buildRowHTML(iconCalendario(), 'A\u00f1o de lanzamiento', marketAnio, premiumAnio, fmtAnio, true);
      if (rowYear) results.insertAdjacentHTML('beforeend', rowYear);
    }
  });
}
</script>
