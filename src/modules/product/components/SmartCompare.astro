---
export interface Props {
  premiumMarca: string;
  premiumModelo: string;
  premiumCamaraMp: number;
  premiumBateriaHoras: number | null;
  premiumLanzamientoAnio: number | null;
}

const {
  premiumMarca,
  premiumModelo,
  premiumCamaraMp,
  premiumBateriaHoras,
  premiumLanzamientoAnio,
} = Astro.props;
---

<div
  id="smart-compare-root"
  class="rounded-2xl border border-slate-800 bg-slate-950/40 p-5"
  data-premium-camara={premiumCamaraMp}
  data-premium-bateria={premiumBateriaHoras ?? ''}
  data-premium-anio={premiumLanzamientoAnio ?? ''}
  data-premium-marca={premiumMarca}
  data-premium-modelo={premiumModelo}
>
  <div class="mb-4 flex items-center gap-2">
    <svg class="h-4 w-4 shrink-0 text-tech-accent-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M16 16v1a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2m5.66 0H14a2 2 0 0 1 2 2v3.34l1 1L23 7v10l-5.34-5.34" />
      <path d="M18 2l4 4-4 4" />
      <path d="M6 12l4-4 4 4" />
    </svg>
    <span class="text-sm font-semibold text-tech-text-primary">Comparar con tu equipo actual</span>
  </div>

  <select
    id="smart-compare-select"
    class="w-full rounded-xl border border-slate-700 bg-slate-900 px-3 py-2.5 text-sm text-tech-text-primary outline-none transition-colors focus:border-tech-accent-blue"
  >
    <option value="">Seleccioná tu equipo actual</option>
  </select>

  <div id="smart-compare-results" class="mt-5 hidden"></div>
</div>

<script>
import marketModels from '../../../data/marketModels.json';

const root = document.getElementById('smart-compare-root');
const select = document.getElementById('smart-compare-select');
const results = document.getElementById('smart-compare-results');

if (
  root &&
  select instanceof HTMLSelectElement &&
  results
) {
  const premiumCamara = parseInt(root.getAttribute('data-premium-camara') ?? '0', 10);
  const premiumBateriaRaw = root.getAttribute('data-premium-bateria') ?? '';
  const premiumBateria = premiumBateriaRaw.length > 0 ? parseInt(premiumBateriaRaw, 10) : null;
  const premiumAnioRaw = root.getAttribute('data-premium-anio') ?? '';
  const premiumAnio = premiumAnioRaw.length > 0 ? parseInt(premiumAnioRaw, 10) : null;
  const premiumMarca = root.getAttribute('data-premium-marca') ?? '';
  const premiumModelo = root.getAttribute('data-premium-modelo') ?? '';

  // Build optgroups
  const brands = Object.keys(marketModels) as Array<keyof typeof marketModels>;
  for (let b = 0; b < brands.length; b++) {
    const brand = brands[b];
    const models = marketModels[brand];
    const group = document.createElement('optgroup');
    group.label = brand;

    for (let m = 0; m < models.length; m++) {
      const entry = models[m];
      const opt = document.createElement('option');
      opt.value = entry.modelo;
      opt.setAttribute('data-brand', brand);
      opt.setAttribute('data-camara', String(entry.camara_mp_numero));
      opt.setAttribute('data-bateria', String(entry.bateria_horas_numero));
      opt.setAttribute('data-anio', String(entry.lanzamiento_anio));
      opt.textContent = brand + ' ' + entry.modelo;
      group.appendChild(opt);
    }

    select.appendChild(group);
  }

  // ── Comparison labels ──
  function labelCamara(v: number): string { return v + ' MP'; }
  function labelBateria(v: number): string { return v + ' h'; }
  function labelAnio(v: number): string { return String(v); }

  // ── Build a single comparison row ──
  function buildRow(
    icon: string,
    label: string,
    marketVal: number | null,
    premiumVal: number | null,
    formatter: (v: number) => string,
    higherIsBetter: boolean,
  ): string {
    if (marketVal === null && premiumVal === null) return '';

    const marketStr = marketVal !== null ? formatter(marketVal) : '—';
    const premiumStr = premiumVal !== null ? formatter(premiumVal) : '—';

    let diffClass = 'text-slate-400';
    let arrow = '→';
    let diffText = '';

    if (marketVal !== null && premiumVal !== null && marketVal !== premiumVal) {
      const diff = premiumVal - marketVal;
      const isGain = higherIsBetter ? diff > 0 : diff < 0;
      const absDiff = Math.abs(diff);
      const pct = marketVal !== 0 ? Math.round((diff / marketVal) * 100) : 0;

      diffClass = isGain ? 'text-emerald-400' : 'text-red-400';
      arrow = isGain ? '↑' : '↓';
      diffText = (isGain ? '+' : '') + (higherIsBetter ? absDiff : -absDiff);
      if (pct !== 0) diffText += ' (' + (isGain ? '+' : '') + pct + '%)';
    }

    return (
      '<div class="flex items-center justify-between rounded-lg bg-slate-900/60 px-3.5 py-2.5">' +
        '<div class="flex items-center gap-2 min-w-0">' +
          '<span class="text-xs text-slate-500 shrink-0">' + icon + '</span>' +
          '<span class="text-xs font-medium text-slate-400">' + label + '</span>' +
        '</div>' +
        '<div class="flex items-center gap-2 shrink-0">' +
          '<span class="text-xs text-slate-400">' + marketStr + '</span>' +
          '<span class="text-xs ' + diffClass + '">' + arrow + '</span>' +
          '<span class="text-xs font-semibold text-white">' + premiumStr + '</span>' +
          (diffText.length > 0 ? '<span class="text-[10px] font-medium ' + diffClass + '">' + diffText + '</span>' : '') +
        '</div>' +
      '</div>'
    );
  }

  // ── Handle selection change ──
  select.addEventListener('change', function () {
    const idx = select.selectedIndex;
    if (idx < 1 || !select.options[idx]) {
      results.classList.add('hidden');
      return;
    }

    const opt = select.options[idx];
    const brand = opt.getAttribute('data-brand') ?? '';
    const marketCamara = parseInt(opt.getAttribute('data-camara') ?? '0', 10);
    const marketBateria = parseInt(opt.getAttribute('data-bateria') ?? '0', 10);
    const marketAnio = parseInt(opt.getAttribute('data-anio') ?? '0', 10);

    const rows: string[] = [];

    rows.push(
      '<div class="mb-3 flex items-center gap-2 border-b border-slate-800 pb-2 text-xs text-slate-500">' +
        '<svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>' +
        '<span>Tu ' + brand + ' <strong class="text-slate-300">' + opt.value + '</strong></span>' +
        '<span class="mx-1 text-slate-600">→</span>' +
        '<span>' + premiumMarca + ' <strong class="text-slate-300">' + premiumModelo + '</strong></span>' +
      '</div>'
    );

    rows.push(buildRow(
      '<svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>',
      'Cámara principal', marketCamara, premiumCamara, labelCamara, true));
    if (premiumBateria !== null) {
      rows.push(buildRow(
        '<svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="6" width="18" height="12" rx="2"/><path d="M23 10v4"/><path d="M7 10l2 3 3-4"/></svg>',
        'Batería (horas)', marketBateria, premiumBateria, labelBateria, true));
    }
    if (premiumAnio !== null) {
      rows.push(buildRow(
        '<svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
        'Año de lanzamiento', marketAnio, premiumAnio, labelAnio, true));
    }

    results.innerHTML = rows.join('\n');
    results.classList.remove('hidden');
  });
}
</script>
