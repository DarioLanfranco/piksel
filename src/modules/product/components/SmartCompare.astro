---
export interface Props {
  premiumMarca: string;
  premiumModelo: string;
  premiumCamaraMp: number;
  premiumBateriaHoras: number | null;
  premiumLanzamientoAnio: number | null;
}

const {
  premiumMarca,
  premiumModelo,
  premiumCamaraMp,
  premiumBateriaHoras,
  premiumLanzamientoAnio,
} = Astro.props;
---

<div
  id="smart-compare-root"
  class="rounded-2xl border border-slate-800 bg-slate-950/40 p-5"
  data-premium-camara={premiumCamaraMp}
  data-premium-bateria={premiumBateriaHoras ?? ''}
  data-premium-anio={premiumLanzamientoAnio ?? ''}
  data-premium-marca={premiumMarca}
  data-premium-modelo={premiumModelo}
>
  <div class="mb-4 flex items-center gap-2">
    <svg class="h-4 w-4 shrink-0 text-tech-accent-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M16 16v1a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2m5.66 0H14a2 2 0 0 1 2 2v3.34l1 1L23 7v10l-5.34-5.34" />
      <path d="M18 2l4 4-4 4" />
      <path d="M6 12l4-4 4 4" />
    </svg>
    <span class="text-sm font-semibold text-tech-text-primary">Comparar con tu equipo actual</span>
  </div>

  <select
    id="smart-compare-select"
    class="w-full rounded-xl border border-slate-700 bg-slate-900 px-3 py-2.5 text-sm text-tech-text-primary outline-none transition-colors focus:border-tech-accent-blue"
  >
    <option value="">Seleccioná tu equipo actual</option>
  </select>

  <div id="smart-compare-results" class="mt-5 hidden"></div>
</div>

<script>
import marketModels from '../../../data/marketModels.json';
import { computeDiff } from '../services/compute-diff';
import type { DiffResult } from '../services/compute-diff';

/* ── Helpers tipados ── */

interface SvgAttr { [key: string]: string | number }

function createSvg(children: Array<{ tag: string; attrs: SvgAttr }>): SVGElement {
  const ns = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(ns, 'svg');
  svg.setAttribute('viewBox', '0 0 24 24');
  svg.setAttribute('class', 'h-3.5 w-3.5 shrink-0');
  svg.setAttribute('fill', 'none');
  svg.setAttribute('stroke', 'currentColor');
  svg.setAttribute('stroke-width', '1.5');
  for (const child of children) {
    const el = document.createElementNS(ns, child.tag);
    for (const [key, val] of Object.entries(child.attrs)) {
      el.setAttribute(key, String(val));
    }
    svg.appendChild(el);
  }
  return svg;
}

function iconCamara(): SVGElement {
  return createSvg([
    { tag: 'path', attrs: { d: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z' } },
    { tag: 'circle', attrs: { cx: 12, cy: 13, r: 4 } },
  ]);
}
function iconBateria(): SVGElement {
  return createSvg([
    { tag: 'rect', attrs: { x: 1, y: 6, width: 18, height: 12, rx: 2 } },
    { tag: 'path', attrs: { d: 'M23 10v4' } },
    { tag: 'path', attrs: { d: 'M7 10l2 3 3-4' } },
  ]);
}
function iconCalendario(): SVGElement {
  return createSvg([
    { tag: 'rect', attrs: { x: 3, y: 4, width: 18, height: 18, rx: 2 } },
    { tag: 'line', attrs: { x1: 16, y1: 2, x2: 16, y2: 6 } },
    { tag: 'line', attrs: { x1: 8, y1: 2, x2: 8, y2: 6 } },
    { tag: 'line', attrs: { x1: 3, y1: 10, x2: 21, y2: 10 } },
  ]);
}
function iconCapa(): SVGElement {
  return createSvg([
    { tag: 'path', attrs: { d: 'M12 2L2 7l10 5 10-5-10-5z' } },
    { tag: 'path', attrs: { d: 'M2 17l10 5 10-5' } },
    { tag: 'path', attrs: { d: 'M2 12l10 5 10-5' } },
  ]);
}

const root = document.getElementById('smart-compare-root');
const select = document.getElementById('smart-compare-select');
const results = document.getElementById('smart-compare-results');

if (root && select instanceof HTMLSelectElement && results) {
  const premiumCamara = parseInt(root.getAttribute('data-premium-camara') ?? '0', 10);
  const premiumBateriaRaw = root.getAttribute('data-premium-bateria') ?? '';
  const premiumBateria = premiumBateriaRaw.length > 0 ? parseInt(premiumBateriaRaw, 10) : null;
  const premiumAnioRaw = root.getAttribute('data-premium-anio') ?? '';
  const premiumAnio = premiumAnioRaw.length > 0 ? parseInt(premiumAnioRaw, 10) : null;
  const premiumMarca = root.getAttribute('data-premium-marca') ?? '';
  const premiumModelo = root.getAttribute('data-premium-modelo') ?? '';

  const brands = Object.keys(marketModels) as Array<keyof typeof marketModels>;
  for (let b = 0; b < brands.length; b++) {
    const brand = brands[b];
    const models = marketModels[brand];
    const group = document.createElement('optgroup');
    group.label = brand;
    for (let m = 0; m < models.length; m++) {
      const entry = models[m];
      const opt = document.createElement('option');
      opt.value = entry.modelo;
      opt.setAttribute('data-brand', brand);
      opt.setAttribute('data-camara', String(entry.camara_mp_numero));
      opt.setAttribute('data-bateria', String(entry.bateria_horas_numero));
      opt.setAttribute('data-anio', String(entry.lanzamiento_anio));
      opt.textContent = brand + ' ' + entry.modelo;
      group.appendChild(opt);
    }
    select.appendChild(group);
  }

  function fmtCamara(v: number): string { return v + ' MP'; }
  function fmtBateria(v: number): string { return v + ' h'; }
  function fmtAnio(v: number): string { return String(v); }

  function createDiffElement(diff: DiffResult): HTMLElement | null {
    if (!diff.diffLabel) return null;
    const el = document.createElement('span');
    el.className = 'text-[10px] font-medium ' + (diff.isGain ? 'text-emerald-400' : 'text-red-400');
    el.textContent = diff.diffLabel;
    return el;
  }

  function buildRow(
    svgIcon: SVGElement,
    label: string,
    marketVal: number | null,
    premiumVal: number | null,
    fmt: (v: number) => string,
    higherIsBetter: boolean,
  ): HTMLElement | null {
    if (marketVal === null && premiumVal === null) return null;

    const marketStr = marketVal !== null ? fmt(marketVal) : '\u2014';
    const premiumStr = premiumVal !== null ? fmt(premiumVal) : '\u2014';

    let diff: DiffResult = { direction: '\u2192', diffLabel: '', isGain: false };
    let diffClass = 'text-slate-400';

    if (marketVal !== null && premiumVal !== null && marketVal !== premiumVal) {
      diff = computeDiff(premiumVal, marketVal, higherIsBetter);
      diffClass = diff.isGain ? 'text-emerald-400' : 'text-red-400';
    }

    const row = document.createElement('div');
    row.className = 'flex items-center justify-between rounded-lg bg-slate-900/60 px-3.5 py-2.5';

    const left = document.createElement('div');
    left.className = 'flex items-center gap-2 min-w-0';

    const iconWrap = document.createElement('span');
    iconWrap.className = 'text-xs text-slate-500 shrink-0';
    iconWrap.appendChild(svgIcon);

    const labelEl = document.createElement('span');
    labelEl.className = 'text-xs font-medium text-slate-400';
    labelEl.textContent = label;

    left.appendChild(iconWrap);
    left.appendChild(labelEl);

    const right = document.createElement('div');
    right.className = 'flex items-center gap-2 shrink-0';

    const marketEl = document.createElement('span');
    marketEl.className = 'text-xs text-slate-400';
    marketEl.textContent = marketStr;

    const arrowEl = document.createElement('span');
    arrowEl.className = 'text-xs ' + diffClass;
    arrowEl.textContent = diff.direction;

    const premiumEl = document.createElement('span');
    premiumEl.className = 'text-xs font-semibold text-white';
    premiumEl.textContent = premiumStr;

    right.appendChild(marketEl);
    right.appendChild(arrowEl);
    right.appendChild(premiumEl);

    const diffEl = createDiffElement(diff);
    if (diffEl) right.appendChild(diffEl);

    row.appendChild(left);
    row.appendChild(right);
    return row;
  }

  select.addEventListener('change', function () {
    const idx = select.selectedIndex;
    if (idx < 1 || !select.options[idx]) {
      results.classList.add('hidden');
      return;
    }

    results.innerHTML = '';
    results.classList.remove('hidden');

    const opt = select.options[idx];
    const brand = opt.getAttribute('data-brand') ?? '';
    const marketCamara = parseInt(opt.getAttribute('data-camara') ?? '0', 10);
    const marketBateria = parseInt(opt.getAttribute('data-bateria') ?? '0', 10);
    const marketAnio = parseInt(opt.getAttribute('data-anio') ?? '0', 10);

    const header = document.createElement('div');
    header.className = 'mb-3 flex items-center gap-2 border-b border-slate-800 pb-2 text-xs text-slate-500';

    const iconWrap = document.createElement('span');
    iconWrap.className = 'flex items-center';
    iconWrap.appendChild(iconCapa());

    const textEl = document.createElement('span');

    const marketStrong = document.createElement('strong');
    marketStrong.className = 'text-slate-300';
    marketStrong.textContent = opt.value;

    const premiumStrong = document.createElement('strong');
    premiumStrong.className = 'text-slate-300';
    premiumStrong.textContent = premiumModelo;

    textEl.appendChild(document.createTextNode('Tu ' + brand + ' '));
    textEl.appendChild(marketStrong);
    textEl.appendChild(document.createTextNode(' \u2192 '));
    textEl.appendChild(document.createTextNode(premiumMarca + ' '));
    textEl.appendChild(premiumStrong);

    header.appendChild(iconWrap);
    header.appendChild(textEl);
    results.appendChild(header);

    const rowCam = buildRow(iconCamara(), 'C\u00e1mara principal', marketCamara, premiumCamara, fmtCamara, true);
    if (rowCam) results.appendChild(rowCam);

    if (premiumBateria !== null) {
      const rowBat = buildRow(iconBateria(), 'Bater\u00eda (horas)', marketBateria, premiumBateria, fmtBateria, true);
      if (rowBat) results.appendChild(rowBat);
    }

    if (premiumAnio !== null) {
      const rowYear = buildRow(iconCalendario(), 'A\u00f1o de lanzamiento', marketAnio, premiumAnio, fmtAnio, true);
      if (rowYear) results.appendChild(rowYear);
    }
  });
}
</script>
