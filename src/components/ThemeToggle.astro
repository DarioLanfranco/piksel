<button
  id="theme-toggle"
  class="flex h-9 w-9 items-center justify-center rounded-full text-tech-text-muted transition-colors hover:bg-tech-bg hover:text-tech-text-primary"
  aria-label="Cambiar tema"
>
  <!-- Sol (visible en modo oscuro → permite cambiar a claro) -->
  <svg id="theme-sun" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Luna (visible en modo claro → permite cambiar a oscuro) -->
  <svg id="theme-moon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
(function () {
  const KEY = 'theme';
  const html = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  const sun = document.getElementById('theme-sun');
  const moon = document.getElementById('theme-moon');

  function syncIcons() {
    const isDark = html.classList.contains('dark');
    if (sun) sun.classList.toggle('hidden', !isDark);
    if (moon) moon.classList.toggle('hidden', isDark);
  }

  function setTheme(mode: string) {
    html.classList.toggle('dark', mode === 'dark');
    localStorage.setItem(KEY, mode);
    syncIcons();
  }

  if (btn) {
    btn.addEventListener('click', function () {
      const next = html.classList.contains('dark') ? 'light' : 'dark';
      setTheme(next);
    });
  }

  syncIcons();
})();
</script>
