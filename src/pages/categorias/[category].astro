---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SheetsProductRepository } from '../../infrastructure/sheets/sheets.repository';
import ProductCard from '../../modules/catalog/components/ProductCard.astro';
import type { Product } from '../../domain/product/product.entity';

export async function getStaticPaths() {
  const repository = SheetsProductRepository.getInstance();
  const products = await repository.findAll();
  const brands = [...new Set(products.map(p => p.marca))];

  return brands.map(brand => ({
    params: { category: brand.toLowerCase() },
    props: {
      brand,
      products: products.filter(p => p.marca.toLowerCase() === brand.toLowerCase()),
    },
  }));
}

const { brand, products } = Astro.props as { brand: string; products: Product[] };
---

<BaseLayout title={brand} description={`Celulares ${brand} en Río Cuarto`}>
  <header class="relative overflow-hidden bg-gradient-to-b from-tech-accent-blue/[0.05] via-transparent to-transparent dark:from-tech-accent-blue/[0.12] dark:via-tech-bg/20 dark:to-transparent">
    <div class="mx-auto max-w-7xl px-4 pt-14 pb-10 sm:px-6 lg:px-8">
      <a href="/" class="no-underline mb-6 inline-flex items-center gap-1.5 text-sm text-tech-text-muted transition-colors duration-200 hover:text-tech-text-secondary">
        <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M10 4l-4 4 4 4" />
        </svg>
        Todas las marcas
      </a>

      <h1 class="text-2xl font-bold text-tech-text-primary">
        {brand}
      </h1>
    </div>
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-tech-border to-transparent" />
  </header>

  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    {products.length === 0 ? (
      <p class="text-sm text-tech-text-muted">No hay productos de esta marca.</p>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {products.map(p => <ProductCard product={p} />)}
      </div>
    )}
  </div>
</BaseLayout>
