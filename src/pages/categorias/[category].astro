---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SheetsProductRepository } from '../../infrastructure/sheets/sheets.repository';
import ProductCard from '../../modules/catalog/components/ProductCard.astro';

export async function getStaticPaths() {
  const repository = new SheetsProductRepository();
  const products = await repository.findAll();
  const brands = [...new Set(products.map(p => p.marca))];

  return brands.map(brand => ({
    params: { category: brand.toLowerCase() },
    props: { brand },
  }));
}

const { brand } = Astro.props;

const repository = new SheetsProductRepository();
const all = await repository.findAll();
const filtered = all.filter(p => p.marca.toLowerCase() === brand.toLowerCase());
---

<BaseLayout title={brand} description={`Celulares ${brand} en Río Cuarto`}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <a href="/" class="mb-6 inline-flex items-center gap-1 text-sm text-tech-text-muted hover:text-tech-text-secondary">
      ← Todas las marcas
    </a>

    <h1 class="text-2xl font-bold text-tech-text-primary mb-8">
      {brand}
    </h1>

    {filtered.length === 0 ? (
      <p class="text-sm text-tech-text-muted">No hay productos de esta marca.</p>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {filtered.map(p => <ProductCard product={p} />)}
      </div>
    )}
  </div>
</BaseLayout>
